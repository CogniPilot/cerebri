include "cerebri2_topics.fbs";

namespace cerebri2.log;

table SchemaRecord {
  name:string;
  bfbs:[ubyte];
}

table FlightSnapshotRecord {
  monotonic_us:ulong;
  payload:cerebri2.topic.FlightSnapshot;
}

table MotorOutputRecord {
  monotonic_us:ulong;
  payload:cerebri2.topic.MotorOutput;
}

union RecordPayload {
  SchemaRecord,
  FlightSnapshotRecord,
  MotorOutputRecord
}

table LogRecord {
  record:RecordPayload;
}

root_type LogRecord;
file_identifier "C2LG";
